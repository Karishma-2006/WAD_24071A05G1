<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

         xsi:schemaLocation="
         https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"

         version="6.0">

    <servlet>

        <servlet-name>
            MedicineBillServlet
        </servlet-name>

        <servlet-class>
            MedicineBillServlet
        </servlet-class>

    </servlet>

    <servlet-mapping>

        <servlet-name>
            MedicineBillServlet
        </servlet-name>

        <url-pattern>
            /bill
        </url-pattern>

    </servlet-mapping>

</web-app>